    y_test = train_data['yield_stress_value'].loc[980:]
    print(y_test)

    #3.建模、计算
    print("===============线性回归计算中===============")
    linear_predict(x_train, x_test, y_train, y_test)

    print("===============RF计算中===============")
    RF_predict(x_train, x_test, y_train, y_test)

    print("===============XGBoost计算中===============")
